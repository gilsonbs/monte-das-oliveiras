---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { supabase, getPostsByCategory, getCategories } from '../../../lib/supabase';

const PER_PAGE = 12;

export async function getStaticPaths() {
  const categories = await getCategories();
  const paths: { params: { slug: string; page: string } }[] = [];

  for (const cat of categories) {
    const { count } = await supabase
      .from('posts')
      .select('id', { count: 'exact', head: true })
      .eq('status', 'published')
      .eq('category_id', cat.id);

    const totalPages = Math.max(1, Math.ceil((count ?? 0) / PER_PAGE));
    for (let p = 2; p <= totalPages; p++) {
      paths.push({ params: { slug: cat.slug, page: String(p) } });
    }
  }
  return paths;
}

const { slug, page: pageParam } = Astro.params;
const page = Number(pageParam);

const categories = await getCategories();
const category = categories.find((c) => c.slug === slug);

if (!category) {
  return Astro.redirect('/404');
}

const { posts, total } = await getPostsByCategory(slug!, page, PER_PAGE);
const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
---

<BaseLayout title={`${category.name} — página ${page}`} description={`Posts sobre ${category.name} — Monte das Oliveiras`}>
  <div class="wrap">
    <div class="page-head">
      <span class="eyebrow">Categoria</span>
      <h1>{category.name}</h1>
      <p class="count">{total} {total === 1 ? 'publicação' : 'publicações'}</p>
    </div>

    <div class="layout">
      <div class="grid-col">
        <div class="grid">
          {posts.map((post) => <PostCard post={post} />)}
        </div>

        <nav class="pagination">
          <a href={page === 2 ? `/categoria/${slug}/` : `/categoria/${slug}/${page - 1}/`}>&larr; Anterior</a>
          <span>Página {page} de {totalPages}</span>
          {page < totalPages && <a href={`/categoria/${slug}/${page + 1}/`}>Próxima &rarr;</a>}
        </nav>
      </div>
      <aside>
        <AdSlot slotKey="sidebar_300x600" />
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .page-head { padding: 44px 0 30px; border-bottom: 1px solid var(--clay-line); margin-bottom: 36px; }
  .page-head h1 { font-family: var(--font-display); font-size: 30px; font-weight: 500; margin: 10px 0 6px; }
  .page-head .count { font-family: var(--font-ui); font-size: 13px; color: #8A8367; margin: 0; }

  .layout { display: grid; grid-template-columns: 1fr 300px; gap: 48px; align-items: start; padding-bottom: 60px; }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }

  .pagination {
    display: flex; align-items: center; justify-content: center; gap: 20px; margin-top: 40px;
    font-family: var(--font-ui); font-size: 13px; color: var(--ink-soft);
  }
  .pagination a { color: var(--olive-deep); font-weight: 500; }

  @media (max-width: 860px) {
    .layout { grid-template-columns: 1fr; }
    .grid { grid-template-columns: 1fr 1fr; }
  }
</style>
