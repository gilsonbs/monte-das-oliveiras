---
import type { PostSummary } from '../lib/supabase';

interface Props {
  post: PostSummary;
}
const { post } = Astro.props;

function timeAgo(dateStr: string) {
  const diff = Date.now() - new Date(dateStr).getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  if (days < 1) return 'Hoje';
  if (days === 1) return 'Há 1 dia';
  if (days < 30) return `Há ${days} dias`;
  return new Date(dateStr).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<a class="card" href={`/${post.slug}`}>
  <div class="card-img">
    {post.card_url && <img src={post.card_url} alt={post.alt_text || post.title} loading="lazy" decoding="async" width="800" height="600" />}
  </div>
  <div class="card-body">
    {post.category_name && <span class="cat">{post.category_name}</span>}
    <h3>{post.title}</h3>
    {post.excerpt && <p class="excerpt">{post.excerpt}</p>}
    <div class="meta">
      {post.read_time_minutes && <span>{post.read_time_minutes} min de leitura</span>}
      <span> · {timeAgo(post.published_at)}</span>
    </div>
  </div>
</a>

<style>
  .card {
    background: var(--card-bg); border: 1px solid var(--clay-line); border-radius: var(--radius);
    overflow: hidden; display: flex; flex-direction: column;
  }
  .card-img {
    aspect-ratio: 4/3; background: linear-gradient(150deg, #8B9560, #59613A);
    overflow: hidden;
  }
  .card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card-body { padding: 18px 18px 20px; }
  .card .cat {
    font-family: var(--font-ui); font-size: 11px; font-weight: 600; letter-spacing: .06em;
    text-transform: uppercase; color: var(--olive-deep); margin-bottom: 8px; display: block;
  }
  .card h3 { font-family: var(--font-display); font-weight: 500; font-size: 18px; line-height: 1.3; margin: 0 0 8px; }
  .card p.excerpt {
    font-size: 14px; color: var(--ink-soft); margin: 0 0 12px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card .meta { font-family: var(--font-ui); font-size: 11px; color: #8A8367; }
</style>
