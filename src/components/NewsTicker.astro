---
import { getPostsByCategory, isTickerEnabled } from '../lib/supabase';

const enabled = await isTickerEnabled().catch(() => false);
const posts = enabled
  ? (await getPostsByCategory('igreja-perseguida', 1, 3).catch(() => ({ posts: [], total: 0 }))).posts
  : [];
---

{enabled && posts.length > 0 && (
  <div class="ticker-bar">
    <div class="ticker-inner">
      <span class="ticker-label">ÚLTIMAS NOTÍCIAS DA IGREJA PERSEGUIDA:</span>
      <div class="ticker-track-wrap">
        <div class="ticker-track">
          {[...posts, ...posts].map((post) => (
            <a href={`/${post.slug}`} class="ticker-item">
              {post.title}
              <span class="ticker-sep" aria-hidden="true"> • </span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
)}

<style>
  .ticker-bar {
    background: var(--dusk);
    border-top: 1px solid rgba(237, 231, 212, 0.12);
    height: 36px;
    overflow: hidden;
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .ticker-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    align-items: center;
    height: 100%;
  }

  .ticker-label {
    flex-shrink: 0;
    background: #E3B15C;
    color: #1a1f33;
    padding: 0 14px;
    height: 100%;
    display: flex;
    align-items: center;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    white-space: nowrap;
    z-index: 1;
  }

  .ticker-track-wrap {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  @media (max-width: 860px) {
    .ticker-inner { padding: 0 20px; }
  }

  .ticker-track {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    animation: ticker-scroll 28s linear infinite;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  .ticker-item {
    color: #CFC9AE;
    transition: color 0.15s;
    padding: 0 4px;
  }

  .ticker-item:hover {
    color: #E3B15C;
  }

  .ticker-sep {
    color: #5a6080;
  }

  @keyframes ticker-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
