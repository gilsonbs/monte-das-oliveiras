---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contato" description="Fale com o Monte das Oliveiras">
  <div class="wrap">
    <div class="contact-page">
      <h1>Contato</h1>
      <p class="intro">Dúvidas, sugestões ou pedidos de correção? Manda uma mensagem.</p>

      <form id="contact-form">
        <label>
          Nome
          <input type="text" id="name" required />
        </label>
        <label>
          E-mail
          <input type="email" id="email" required />
        </label>
        <label>
          Mensagem
          <textarea id="message" rows="6" required></textarea>
        </label>
        <button type="submit" id="submit-btn">Enviar mensagem</button>
        <p id="feedback" class="feedback" hidden></p>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  import { createSupabaseBrowserClient } from '../lib/supabase-browser';

  const supabase = createSupabaseBrowserClient();
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const feedback = document.getElementById('feedback') as HTMLParagraphElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    const { error } = await supabase.from('contact_messages').insert({ name, email, message });

    if (error) {
      feedback.textContent = 'Não foi possível enviar agora. Tenta de novo em instantes.';
      feedback.className = 'feedback error';
      feedback.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar mensagem';
      return;
    }

    form.reset();
    feedback.textContent = 'Mensagem enviada! Vamos responder assim que possível.';
    feedback.className = 'feedback success';
    feedback.hidden = false;
    submitBtn.textContent = 'Enviada ✓';
  });
</script>

<style>
  .contact-page { max-width: 560px; margin: 0 auto; padding: 50px 0 70px; }
  .contact-page h1 { font-family: var(--font-display); font-size: 32px; font-weight: 500; margin-bottom: 8px; }
  .contact-page .intro { color: var(--ink-soft); margin-bottom: 30px; }

  form { display: flex; flex-direction: column; gap: 18px; }
  label { font-family: var(--font-ui); font-size: 13px; font-weight: 500; color: var(--ink-soft); display: flex; flex-direction: column; gap: 6px; }
  input, textarea {
    font-family: var(--font-ui); font-size: 14px; padding: 10px 12px; border: 1px solid var(--clay-line);
    border-radius: 4px; background: var(--card-bg); color: var(--ink); resize: vertical;
  }
  input:focus, textarea:focus { outline: none; border-color: var(--olive); }

  button {
    align-self: flex-start; font-family: var(--font-ui); font-size: 13px; font-weight: 600;
    padding: 11px 22px; border-radius: 4px; border: none; background: var(--olive); color: #fff; cursor: pointer;
  }
  button:disabled { opacity: .7; cursor: default; }

  .feedback { font-family: var(--font-ui); font-size: 13px; margin: 0; }
  .feedback.success { color: var(--olive-deep); }
  .feedback.error { color: #A6462A; }
</style>
