# Settings > Data API (Project URL) e Settings > API Keys (Publishable key)
# no painel do Supabase. Essa é a chave pública de LEITURA — protegida por RLS,
# então é segura de expor no front-end (nunca use a secret/service_role aqui).
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ID de medição do Google Analytics (GA4) — não é secreto, sempre exposto no client
PUBLIC_GA_MEASUREMENT_ID=G-FRF66SPD2W
